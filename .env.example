# DANVERSE-X Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# Analytics & Tracking
# ============================================

# Google Tag Manager ID
NEXT_PUBLIC_GTM_ID=GTM-NFLHXXGK

# Google Analytics ID
NEXT_PUBLIC_GA_ID=G-W6LV22900R

# ============================================
# Feature Flags (Optional)
# ============================================

# Enable/disable 3D robot background
# NEXT_PUBLIC_ENABLE_3D=true

# Enable/disable WebGL plasma effects
# NEXT_PUBLIC_ENABLE_PLASMA=true

# ============================================
# Development (Optional)
# ============================================

# Enable debug logging in development
# NEXT_PUBLIC_DEBUG=false

# n8n Automation (Oracle VPS)
NEXT_PUBLIC_N8N_BASE_URL=https://n8n.danverse.ai

# Admin Panel
# Set a strong password in Netlify env vars — never commit the real value
NEXT_PUBLIC_ADMIN_PASSWORD=change_me_in_production
