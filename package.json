{
  "name": "danverse-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check": "tsc --noEmit && npm run lint && npm run build",
    "dev": "next dev",
    "lint": "next lint",
    "optimize": "node scripts/optimize-images.mjs",
    "prebuild": "node scripts/generate-static-headers.mjs",
    "postbuild": "npm run verify:sitemap",
    "start": "next start",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:a11y": "vitest run __tests__/accessibility.test.tsx",
    "test:all": "npm run test:unit && npm run test:a11y && npm run test:e2e",
    "verify:sitemap": "node scripts/verify-sitemap.mjs",
    "test:e2e": "npm run build && playwright test",
    "bundlesize": "node -r ./scripts/bundlesize-fallback.cjs ./node_modules/bundlesize/index.js --config bundlesize.config.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "latest",
    "@radix-ui/react-alert-dialog": "latest",
    "@radix-ui/react-aspect-ratio": "latest",
    "@radix-ui/react-avatar": "latest",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-collapsible": "latest",
    "@radix-ui/react-context-menu": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-hover-card": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-menubar": "latest",
    "@radix-ui/react-navigation-menu": "latest",
    "@radix-ui/react-popover": "latest",
    "@radix-ui/react-progress": "latest",
    "@radix-ui/react-radio-group": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slider": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "latest",
    "@radix-ui/react-tabs": "latest",
    "@radix-ui/react-toast": "latest",
    "@radix-ui/react-toggle": "latest",
    "@radix-ui/react-toggle-group": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@sentry/nextjs": "^10.46.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "latest",
    "date-fns": "4.1.0",
    "embla-carousel-react": "latest",
    "framer-motion": "^12.38.0",
    "geist": "^1.3.1",
    "input-otp": "latest",
    "lenis": "^1.3.21",
    "lucide-react": "^0.454.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-day-picker": "latest",
    "react-dom": "^18.3.1",
    "react-hook-form": "latest",
    "react-resizable-panels": "latest",
    "recharts": "latest",
    "sonner": "latest",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "latest",
    "zod": "3.25.67"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "bundlesize": "^0.18.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.2.10",
    "postcss": "^8.5",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,mdx,mjs}": [
      "prettier --write"
    ]
  }
}
